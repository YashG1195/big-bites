PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/bigbites
REDIS_URL=redis://localhost:6379

# Firebase Admin SDK configuration (Service Account JSON fields)
FIREBASE_PROJECT_ID=dummy-project-id
FIREBASE_CLIENT_EMAIL=dummy@dummy.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nDummyKey\n-----END PRIVATE KEY-----\n"

# Razorpay (For later)
RAZORPAY_KEY_ID=dummy_key_id
RAZORPAY_KEY_SECRET=dummy_key_secret

# Sentry (Error Monitoring)
SENTRY_DSN=your_sentry_dsn_here
