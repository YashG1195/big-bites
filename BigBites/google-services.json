{
  "_PLACEHOLDER": true,
  "_INSTRUCTIONS": [
    "1. Go to https://console.firebase.google.com",
    "2. Select your project (or create one named 'BigBites')",
    "3. Click the Android icon to add an Android app",
    "4. Package name: com.bigbites",
    "5. Download google-services.json",
    "6. REPLACE this entire file with the downloaded google-services.json",
    "7. Place it at: BigBites/google-services.json  (this exact location)"
  ],
  "project_info": {
    "project_number": "YOUR_PROJECT_NUMBER",
    "project_id": "YOUR_PROJECT_ID",
    "storage_bucket": "YOUR_PROJECT_ID.appspot.com"
  },
  "client": [
    {
      "client_info": {
        "mobilesdk_app_id": "1:YOUR_PROJECT_NUMBER:android:YOUR_APP_ID",
        "android_client_info": {
          "package_name": "com.bigbites"
        }
      },
      "services": {
        "appinvite_service": {
          "other_platform_oauth_client": []
        }
      }
    }
  ],
  "configuration_version": "1"
}
